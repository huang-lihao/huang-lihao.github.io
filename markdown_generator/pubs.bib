@article{huangFEMbasedHomogenizationMethod2023,
  title = {An {{FEM-based}} Homogenization Method for Orthogonal Lattice Metamaterials within Micropolar Elasticity},
  author = {Huang, Lihao and Yuan, Huang and Zhao, Haiyan},
  year = {2023},
  month = jan,
  journal = {International Journal of Mechanical Sciences},
  volume = {238},
  pages = {107836},
  issn = {0020-7403},
  doi = {10.1016/j.ijmecsci.2022.107836},
  abstract = {Lattice metamaterials are widely used in weight-critical applications and gain more design freedoms with the development of additive manufacturing technology, which requires new accurate homogenization methods to model the mechanical behavior of complex microstructures. In the present work, a new homogenization method based on finite element methods was proposed within the frame of the anisotropic micropolar continuum for the metamaterial, which provided a general approach for both homogeneous and conformal metamaterials of orthogonal lattices. The mapping relation between lattice and finite element mesh as well as edge effects were clarified and modeled. The homogenization approach is verified based on detailed modal analysis and shows high numerical accuracy for engineering applications. Computational experiments confirmed that the micropolar model provides much more accurate results than the classical continuum.},
  copyright = {All rights reserved},
  langid = {english},
  language = {en}
}

@article{zhouNovelRoboticControl2022,
  title = {A {{Novel Robotic Control System Mimics Doctor}}'s {{Operation}} to {{Assist Percutaneous Coronary Intervention}}},
  author = {Zhou, Boda and Li, Qizhong and Xue, Yajun and Huang, Lihao and Zhou, Jie and Zhang, Ou and Zhang, Ping and Zheng, Gangtie},
  year = {2022},
  month = sep,
  journal = {Cardiovascular Innovations and Applications},
  publisher = {{Compuscript}},
  issn = {2009-8618},
  doi = {10.15212/CVIA.2022.0003},
  abstract = {{$<$}p class="first" id="d196565e212"{$>$} \textbf{Objectives:} The use of current robotic systems to assist in percutaneous coronary intervention (PCI) fundamentally differs from performing conventional PCI. To overcome this problem, we developed a novel master-slave robotic control system to assist in PCI, and evaluated its safety and feasibility in the delivery and manipulation of coronary guidewires \emph{in vitro} and \emph{in vivo}. {$<$}/p{$><$}p id="d196565e223"{$>$} \textbf{Methods:} The novel robotic assist PCI system is composed of three parts: 1) a master actuator, which imitates the traditional torque used by surgeons in conventional PCI, 2) a slave actuator, including a guidewire delivery system and force monitoring equipment, and 3) a local area network based communication system. {$<$}/p{$><$}p id="d196565e228"{$>$} \textbf{Results:} The experiment was performed in six pigs. Both robotic and manual control completed the operation with no device- or procedure-associated complications. An experienced interventional cardiologist who was a first-time user of the novel robotic PCI system was able to advance the guidewire into a distal branch of a coronary artery within a similar time to that required with the manual procedure. {$<$}/p{$><$}p id="d196565e233"{$>$} \textbf{Conclusion:} This early \emph{in vivo} experiment with the novel robotic assisted PCI control system demonstrated that its feasibility, safety, and procedural effectiveness are comparable to those of manual operation. The novel robotic-assisted PCI control system required significantly less time to learn than other currently available systems. {$<$}/p{$>$}},
  copyright = {All rights reserved}
}
